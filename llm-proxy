#!/bin/bash
# llm-proxy - APIキーを安全にキャッシュして、ローカルプロキシ経由でLLMにアクセスするツール
# Usage: llm-proxy <command>
#   init    - APIキーを設定する
#   start   - プロキシをバックグラウンドで起動する
#   stop    - プロキシを停止する
#   status  - プロキシの状態を確認する
#   env     - 設定すべき環境変数を表示する
#   restart - プロキシを再起動する

set -euo pipefail

# ============================================================
# 定数・設定
# ============================================================
CONFIG_DIR="$HOME/.llm-proxy"
CONFIG_FILE="$CONFIG_DIR/config"
LITELLM_CONFIG="$CONFIG_DIR/litellm-config.yaml"
PID_FILE="$CONFIG_DIR/proxy.pid"
LOG_FILE="$CONFIG_DIR/proxy.log"
DEFAULT_PORT=4000
DUMMY_API_KEY="sk-dummy-safe-proxy-key-0000"

# ============================================================
# カラー出力
# ============================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

info()    { echo -e "${BLUE}[INFO]${RESET} $*"; }
success() { echo -e "${GREEN}[OK]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${RESET} $*"; }
error()   { echo -e "${RED}[ERROR]${RESET} $*" >&2; }
header()  { echo -e "\n${BOLD}${CYAN}$*${RESET}"; }

# ============================================================
# サービス定義
# 形式: "ENV_VAR_NAME|表示名|キーの例|モデル定義（カンマ区切り: モデル名=litellmパス）"
#
# 新しいサービスを追加するにはここに1行足すだけ。
# ============================================================
SERVICES=(
  "ANTHROPIC_API_KEY_REAL|Anthropic (Claude)|sk-ant-...|claude-sonnet=anthropic/claude-3-5-sonnet-20241022,claude-haiku=anthropic/claude-3-5-haiku-20241022,claude-opus=anthropic/claude-3-opus-20240229,claude-3-5-sonnet-20241022=anthropic/claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022=anthropic/claude-3-5-haiku-20241022,claude-sonnet-4-5=anthropic/claude-sonnet-4-5,claude-haiku-4-5-20251001=anthropic/claude-haiku-4-5-20251001,claude-opus-4-6=anthropic/claude-opus-4-6,claude-sonnet-4-6=anthropic/claude-sonnet-4-6"
  "OPENAI_API_KEY_REAL|OpenAI (GPT)|sk-...|gpt-4o=openai/gpt-4o,gpt-4o-mini=openai/gpt-4o-mini,gpt-4-turbo=openai/gpt-4-turbo,o1=openai/o1,o1-mini=openai/o1-mini,o3-mini=openai/o3-mini"
  "GOOGLE_API_KEY_REAL|Google (Gemini)|AIza...|gemini-pro=gemini/gemini-1.5-pro,gemini-flash=gemini/gemini-1.5-flash,gemini-2-flash=gemini/gemini-2.0-flash,gemini-2-pro=gemini/gemini-2.0-pro"
  "XAI_API_KEY_REAL|xAI (Grok)|xai-...|grok-2=xai/grok-2,grok-2-mini=xai/grok-2-mini,grok-beta=xai/grok-beta"
  "MISTRAL_API_KEY_REAL|Mistral AI|...|mistral-large=mistral/mistral-large-latest,mistral-small=mistral/mistral-small-latest,codestral=mistral/codestral-latest"
  "COHERE_API_KEY_REAL|Cohere|...|command-r-plus=cohere/command-r-plus,command-r=cohere/command-r,command=cohere/command"
  "DEEPSEEK_API_KEY_REAL|DeepSeek|sk-...|deepseek-chat=deepseek/deepseek-chat,deepseek-coder=deepseek/deepseek-coder,deepseek-r1=deepseek/deepseek-reasoner"
  "GROQ_API_KEY_REAL|Groq|gsk_...|llama3-70b=groq/llama3-70b-8192,llama3-8b=groq/llama3-8b-8192,mixtral-8x7b=groq/mixtral-8x7b-32768"
  "PERPLEXITY_API_KEY_REAL|Perplexity|pplx-...|pplx-sonar-large=perplexity/llama-3.1-sonar-large-128k-online,pplx-sonar-small=perplexity/llama-3.1-sonar-small-128k-online"
  "TOGETHER_API_KEY_REAL|Together AI|...|llama-3-70b=together_ai/meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo,llama-3-8b=together_ai/meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo"
)

# サービス情報を取得するヘルパー
svc_env()     { echo "${1%%|*}"; }                                      # 環境変数名
svc_name()    { local s="${1#*|}"; echo "${s%%|*}"; }                  # 表示名
svc_example() { local s="${1#*|*|}"; echo "${s%%|*}"; }                # キーの例
svc_models()  { echo "${1##*|}"; }                                      # モデル定義文字列

# ============================================================
# ヘルパー関数
# ============================================================

ensure_config_dir() {
  if [ ! -d "$CONFIG_DIR" ]; then
    mkdir -p "$CONFIG_DIR"
    chmod 700 "$CONFIG_DIR"
  fi
}

load_config() {
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
}

check_litellm() {
  if ! command -v litellm &>/dev/null; then
    warn "LiteLLMがインストールされていません。"
    echo ""
    read -r -p "今すぐインストールしますか？ [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      info "LiteLLMをインストール中..."
      if command -v pip3 &>/dev/null; then
        pip3 install 'litellm[proxy]' --quiet
      elif command -v pip &>/dev/null; then
        pip install 'litellm[proxy]' --quiet
      else
        error "pipが見つかりません。Pythonをインストールしてください。"
        echo "  → https://www.python.org/downloads/"
        exit 1
      fi
      success "LiteLLMのインストール完了"
    else
      error "LiteLLMが必要です。以下のコマンドでインストールしてください："
      echo "  pip install 'litellm[proxy]'"
      exit 1
    fi
  fi
}

is_running() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid=$(cat "$PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    else
      rm -f "$PID_FILE"
      return 1
    fi
  fi
  return 1
}

# ============================================================
# LiteLLM設定ファイル生成（サービス定義をループで処理）
# ============================================================
generate_litellm_config() {
  load_config

  # 1つもキーが設定されていないか確認
  local any_key=0
  for svc in "${SERVICES[@]}"; do
    local env_var
    env_var=$(svc_env "$svc")
    if [ -n "$(eval "echo \"\${${env_var}:-}\"")" ]; then
      any_key=1
      break
    fi
  done

  if [ "$any_key" -eq 0 ]; then
    error "APIキーが設定されていません。まず 'llm-proxy init' を実行してください。"
    exit 1
  fi

  cat > "$LITELLM_CONFIG" << YAML
# llm-proxy が自動生成した LiteLLM 設定ファイル
# このファイルは ~/.llm-proxy/ に保存されており、プロジェクト外のため安全です

model_list:
YAML

  for svc in "${SERVICES[@]}"; do
    local env_var
    env_var=$(svc_env "$svc")
    local api_key
    api_key="$(eval "echo \"\${${env_var}:-}\"")"
    [ -z "$api_key" ] && continue

    local models_str
    models_str=$(svc_models "$svc")

    # カンマ区切りのモデル定義をループ
    IFS=',' read -ra model_entries <<< "$models_str"
    for entry in "${model_entries[@]}"; do
      local model_name="${entry%%=*}"
      local litellm_model="${entry##*=}"
      cat >> "$LITELLM_CONFIG" << YAML
  - model_name: ${model_name}
    litellm_params:
      model: ${litellm_model}
      api_key: "${api_key}"

YAML
    done
  done

  cat >> "$LITELLM_CONFIG" << YAML
litellm_settings:
  drop_params: true

general_settings:
  master_key: "${DUMMY_API_KEY}"
YAML

  chmod 600 "$LITELLM_CONFIG"
}

# ============================================================
# init ヘルパー: サービス名を環境変数名に変換
# エイリアスにより "Claude" "claude-code" なども ANTHROPIC_API_KEY_REAL に正規化される
# ============================================================
_name_to_env_var() {
  local name="$1"
  # まず大文字に正規化
  local upper
  upper=$(printf '%s' "$name" | tr 'a-z' 'A-Z' | tr -cs 'A-Z0-9' '_' | sed 's/^_*//' | sed 's/_*$//')

  # エイリアス解決: よく使われる別名を正規の変数名にマッピング
  case "$upper" in
    CLAUDE|CLAUDE_CODE|CLAUDECODE|CLAUDE_AI|ANTHROPIC_CLAUDE)
      echo "ANTHROPIC_API_KEY_REAL"; return ;;
    CHATGPT|CHAT_GPT|GPT|GPT4|GPT_4|GPT4O|GPT_4O)
      echo "OPENAI_API_KEY_REAL"; return ;;
    GEMINI|GOOGLE_GEMINI|GOOGLE_AI|BARD)
      echo "GOOGLE_API_KEY_REAL"; return ;;
    GROK|XAI_GROK)
      echo "XAI_API_KEY_REAL"; return ;;
    MISTRAL_LARGE|MISTRAL_SMALL|CODESTRAL)
      echo "MISTRAL_API_KEY_REAL"; return ;;
    COMMAND|COMMAND_R|COHERE_AI)
      echo "COHERE_API_KEY_REAL"; return ;;
    DEEPSEEK_CHAT|DEEPSEEK_CODER|DEEPSEEK_R1)
      echo "DEEPSEEK_API_KEY_REAL"; return ;;
    LLAMA|LLAMA3|MIXTRAL|GROQ_AI)
      echo "GROQ_API_KEY_REAL"; return ;;
    PPLX|PERPLEXITY_AI|SONAR)
      echo "PERPLEXITY_API_KEY_REAL"; return ;;
    TOGETHER|TOGETHER_AI|TOGETHERAI)
      echo "TOGETHER_API_KEY_REAL"; return ;;
  esac

  # エイリアスにない場合はそのまま変換
  echo "${upper}_API_KEY_REAL"
}

# 登録済みAPIキーを番号付きで表示（作業用tmpファイルから読む）
_show_registered_keys_numbered() {
  local file="$1"
  echo "登録済みのAPIキー:"
  if [ ! -s "$file" ]; then
    echo "  (なし)"
    return
  fi
  local n=0
  while IFS='=' read -r key val; do
    [ -z "$key" ] && continue
    n=$((n + 1))
    local svc_display="${key%_API_KEY_REAL}"
    local masked="${val:0:8}...${val: -4}"
    echo "  $n. $svc_display: $masked"
  done < "$file"
}

# ============================================================
# コマンド: init
# ============================================================
cmd_init() {
  header "llm-proxy セットアップ"
  echo "APIキーをセキュアな場所 [$CONFIG_DIR] に保存します。"
  echo "プロジェクトの .env ファイルには一切書き込みません。"
  echo ""

  ensure_config_dir
  load_config

  # ポート設定
  local current_port="${PROXY_PORT:-$DEFAULT_PORT}"
  echo -n "プロキシのポート番号 [${current_port}]: "
  read -r input_port
  local port="${input_port:-$current_port}"

  # 既存キーを作業用tmpファイルにコピー
  local tmp_keys
  tmp_keys=$(mktemp)
  if [ -f "$CONFIG_FILE" ]; then
    grep '_API_KEY_REAL=' "$CONFIG_FILE" >> "$tmp_keys" || true
  fi

  # メインループ: 追加・更新・削除
  while true; do
    echo ""
    _show_registered_keys_numbered "$tmp_keys"
    echo ""
    echo "操作: サービス名を入力して追加・更新 / [d 番号] で削除 / [Enter] で完了"
    echo -n "> "
    read -r user_input

    # 空Enter → 完了
    [ -z "$user_input" ] && break

    # "d N" → 削除
    if echo "$user_input" | grep -qE '^d [0-9]+$'; then
      local del_num="${user_input#d }"
      local del_key
      del_key=$(sed -n "${del_num}p" "$tmp_keys" | cut -d= -f1)
      if [ -n "$del_key" ]; then
        local tmp2
        tmp2=$(mktemp)
        grep -v "^${del_key}=" "$tmp_keys" > "$tmp2" || true
        mv "$tmp2" "$tmp_keys"
        local svc_display="${del_key%_API_KEY_REAL}"
        success "$svc_display を削除しました"
      else
        warn "番号 $del_num は存在しません"
      fi
      continue
    fi

    # それ以外 → サービス名として追加・更新
    local svc_name="$user_input"
    local env_var
    env_var=$(_name_to_env_var "$svc_name")

    local current_val
    current_val=$(grep "^${env_var}=" "$tmp_keys" 2>/dev/null | tail -1 | cut -d= -f2- || true)

    if [ -n "$current_val" ]; then
      local masked="${current_val:0:8}...${current_val: -4}"
      echo "  現在の値: $masked"
      echo -n "  新しいAPIキー (変更しない場合はEnter): "
    else
      echo -n "  APIキー: "
    fi
    read -r -s input_key
    echo ""

    local new_val="${input_key:-$current_val}"
    if [ -n "$new_val" ]; then
      local tmp2
      tmp2=$(mktemp)
      grep -v "^${env_var}=" "$tmp_keys" > "$tmp2" || true
      echo "${env_var}=${new_val}" >> "$tmp2"
      mv "$tmp2" "$tmp_keys"
      success "$svc_name を保存しました"
    fi
  done

  # 1つも設定されていない場合はエラー
  if [ ! -s "$tmp_keys" ]; then
    rm -f "$tmp_keys"
    error "少なくとも1つのAPIキーを設定してください。"
    exit 1
  fi

  # 設定ファイルに保存
  {
    echo "# llm-proxy 設定ファイル"
    echo "# このファイルは $CONFIG_DIR に保存されています"
    echo "# パーミッション 600（本人のみ読み取り可能）に設定されています"
    echo ""
    echo "PROXY_PORT=${port}"
    cat "$tmp_keys"
  } > "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
  rm -f "$tmp_keys"

  PROXY_PORT="$port"
  load_config
  generate_litellm_config

  success "設定を保存しました: $CONFIG_FILE"
  echo ""
  info "次のコマンドでプロキシを起動できます："
  echo "  llm-proxy start"
}

# ============================================================
# コマンド: start
# ============================================================
cmd_start() {
  load_config

  if is_running; then
    local pid
    pid=$(cat "$PID_FILE")
    warn "プロキシはすでに起動中です (PID: $pid, Port: ${PROXY_PORT:-$DEFAULT_PORT})"
    return 0
  fi

  check_litellm

  if [ ! -f "$CONFIG_FILE" ]; then
    error "設定ファイルが見つかりません。まず 'llm-proxy init' を実行してください。"
    exit 1
  fi

  generate_litellm_config

  local port="${PROXY_PORT:-$DEFAULT_PORT}"
  info "プロキシを起動中... (Port: $port)"

  nohup litellm --config "$LITELLM_CONFIG" --port "$port" \
    > "$LOG_FILE" 2>&1 &
  local pid=$!
  echo "$pid" > "$PID_FILE"

  local max_wait=10
  local waited=0
  while [ $waited -lt $max_wait ]; do
    if curl -s "http://localhost:$port/health" &>/dev/null; then
      success "プロキシが起動しました！"
      echo ""
      cmd_env
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
    echo -n "."
  done
  echo ""

  if ! is_running; then
    error "プロキシの起動に失敗しました。ログを確認してください："
    echo "  cat $LOG_FILE"
    exit 1
  fi

  success "プロキシが起動しました (PID: $pid)"
  echo ""
  cmd_env
}

# ============================================================
# コマンド: stop
# ============================================================
cmd_stop() {
  if ! is_running; then
    warn "プロキシは起動していません。"
    return 0
  fi

  local pid
  pid=$(cat "$PID_FILE")
  info "プロキシを停止中... (PID: $pid)"
  kill "$pid" 2>/dev/null || true
  rm -f "$PID_FILE"
  success "プロキシを停止しました。"
}

# ============================================================
# コマンド: restart
# ============================================================
cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

# ============================================================
# コマンド: status
# ============================================================
cmd_status() {
  load_config
  local port="${PROXY_PORT:-$DEFAULT_PORT}"

  header "llm-proxy ステータス"

  if is_running; then
    local pid
    pid=$(cat "$PID_FILE")
    success "起動中 (PID: $pid, Port: $port)"
    if curl -s "http://localhost:$port/health" &>/dev/null; then
      success "ヘルスチェック: 正常"
    else
      warn "ヘルスチェック: 応答なし（起動中の可能性あり）"
    fi
  else
    warn "停止中"
  fi

  echo ""
  echo "設定ファイル: $CONFIG_FILE"
  echo "LiteLLM設定:  $LITELLM_CONFIG"
  echo "ログファイル: $LOG_FILE"

  if [ -f "$CONFIG_FILE" ]; then
    echo ""
    echo "登録済みAPIキー:"
    local found=0
    for svc in "${SERVICES[@]}"; do
      local env_var name
      env_var=$(svc_env "$svc")
      name=$(svc_name "$svc")
      local val
      val="$(eval "echo \"\${${env_var}:-}\"")"
      if [ -n "$val" ]; then
        local masked="${val:0:8}...${val: -4}"
        printf "  %-28s %s\n" "${name}:" "$masked"
        found=1
      fi
    done
    [ "$found" -eq 0 ] && echo "  （なし）"
  fi
}

# ============================================================
# コマンド: env
# ============================================================
cmd_env() {
  load_config
  local port="${PROXY_PORT:-$DEFAULT_PORT}"

  header "環境変数の設定方法"
  echo "以下をターミナルで実行（またはシェルの設定ファイルに追加）してください："
  echo ""
  echo -e "${YELLOW}# Anthropic (Claude Code, Antigravity など)${RESET}"
  echo "export ANTHROPIC_BASE_URL=http://localhost:${port}"
  echo "export ANTHROPIC_API_KEY=${DUMMY_API_KEY}"
  echo ""
  echo -e "${YELLOW}# OpenAI互換ツール${RESET}"
  echo "export OPENAI_BASE_URL=http://localhost:${port}"
  echo "export OPENAI_API_KEY=${DUMMY_API_KEY}"
  echo ""
  echo -e "${CYAN}# ワンライナー（コピペ用）${RESET}"
  echo "export ANTHROPIC_BASE_URL=http://localhost:${port} ANTHROPIC_API_KEY=${DUMMY_API_KEY} OPENAI_BASE_URL=http://localhost:${port} OPENAI_API_KEY=${DUMMY_API_KEY}"
  echo ""
  echo -e "${BOLD}重要：${RESET} .env ファイルや .claude ファイルには本物のAPIキーを書かないでください。"
  echo "         ダミーキー [${DUMMY_API_KEY}] のみ使用します。"
}

# ============================================================
# コマンド: services
# ============================================================
cmd_services() {
  load_config

  header "対応サービス一覧"
  echo ""
  printf "  %-4s %-28s %-16s %s\n" "状態" "サービス" "変数名" "登録モデル数"
  echo "  ──────────────────────────────────────────────────────────"

  for svc in "${SERVICES[@]}"; do
    local env_var name models_str
    env_var=$(svc_env "$svc")
    name=$(svc_name "$svc")
    models_str=$(svc_models "$svc")
    local val
    val="$(eval "echo \"\${${env_var}:-}\"")"

    # モデル数を数える
    local model_count
    model_count=$(echo "$models_str" | tr ',' '\n' | wc -l | tr -d ' ')

    if [ -n "$val" ]; then
      printf "  ${GREEN}[ON] ${RESET} %-28s %-16s %s モデル\n" "$name" "$env_var" "$model_count"
    else
      printf "  ${YELLOW}[--] ${RESET} %-28s %-16s %s モデル\n" "$name" "$env_var" "$model_count"
    fi
  done

  echo ""
  info "キーを追加・変更するには: llm-proxy init"
}

# ============================================================
# コマンド: update
# ============================================================
cmd_update() {
  local repo="shiro00132343/llm-proxy-run"
  local install_path
  install_path="$(command -v llm-proxy)"

  info "最新版を確認中..."

  # GitHub APIでHEADのSHAを取得（CDNキャッシュを回避）
  local sha
  sha=$(curl -fsSL "https://api.github.com/repos/${repo}/commits/main" 2>/dev/null \
    | grep '"sha"' | head -1 \
    | sed 's/.*"sha": *"\([^"]*\)".*/\1/')

  if [ -z "$sha" ]; then
    error "GitHubへの接続に失敗しました。ネットワークを確認してください。"
    exit 1
  fi

  local url="https://raw.githubusercontent.com/${repo}/${sha}/llm-proxy"
  info "ダウンロード中... (${sha:0:7})"
  curl -fsSL "$url" -o "$install_path"
  chmod +x "$install_path"
  success "アップデート完了: $install_path"

  local version
  version=$(grep '^# llm-proxy' "$install_path" | head -1)
  [ -n "$version" ] && echo "  $version"
}

# ============================================================
# コマンド: logs
# ============================================================
cmd_logs() {
  if [ ! -f "$LOG_FILE" ]; then
    warn "ログファイルが見つかりません: $LOG_FILE"
    return 0
  fi
  tail -f "$LOG_FILE"
}

