  2. llm-proxy start   # プロキシ起動
  3. 表示された環境変数をシェルに設定
  4. Claude Code / Antigravity などをそのまま使う

${BOLD}セキュリティ:${RESET}
  - 本物のAPIキーは $CONFIG_DIR に保存されます
  - パーミッション 600（本人のみ読み取り可能）
  - プロジェクトの .env には絶対に書き込みません
  - ツールが読み取るのはダミーキーのみです

EOF
}

# ============================================================
# メイン処理
# ============================================================
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)     cmd_init "$@" ;;
    start)    cmd_start "$@" ;;
    stop)     cmd_stop "$@" ;;
    restart)  cmd_restart "$@" ;;
    status)   cmd_status "$@" ;;
    services) cmd_services "$@" ;;
    env)      cmd_env "$@" ;;
    logs)     cmd_logs "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
      error "不明なコマンド: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
